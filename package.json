{
  "name": "turabian-md",
  "version": "0.1.0",
  "description": "Convert academic Markdown papers into Turabian-style DOCX files.",
  "bin": {
    "md2doc": "./bin/md2doc.js",
    "md2pdf": "./bin/md2pdf",
    "md2check": "./bin/md2check.js",
    "md_to_docx.js": "./bin/md_to_docx.js"
  },
  "scripts": {
    "test": "node ./tests/check-fixtures.js",
    "smoke": "node ./bin/md2doc.js examples/sample-paper.md /tmp/turabian-md-sample.docx",
    "smoke:pdf": "./bin/md2pdf examples/sample-paper.md /tmp/turabian-md-sample.pdf"
  },
  "keywords": [
    "markdown",
    "docx",
    "turabian",
    "chicago",
    "academic"
  ],
  "author": "Yi Hyan Yoon",
  "license": "MIT",
  "dependencies": {
    "docx": "^9.6.1"
  }
}
